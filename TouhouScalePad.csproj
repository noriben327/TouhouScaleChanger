<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>TouhouScalePad</AssemblyName>
    <RootNamespace>TouhouScalePad</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <ApplicationIcon>Assets\TouhouScalePad.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="TouhouScalePad.SmokeTests\**\*.cs" />
    <EmbeddedResource Remove="TouhouScalePad.SmokeTests\**\*" />
    <None Remove="TouhouScalePad.SmokeTests\**\*" />
  </ItemGroup>
  <ItemGroup>
    <Resource Include="Assets\TouhouScalePad.ico" />
  </ItemGroup>
</Project>
